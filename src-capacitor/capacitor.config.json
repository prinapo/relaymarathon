{
  "appId": "com.prinapo.relaymarathon",
  "appName": "Milano Relay Marathon",
  "webDir": "../dist/spa",
  "androidPackageFormat": "debug",
  "plugins": {
    "SocialLogin": {
      "providers": {
        "google": true,
        "apple": true,
        "facebook": false,
        "twitter": false
      },
      "logLevel": 1
    },
    "SystemBars": {
      "insetsHandling": "disable"
    },
    "EdgeToEdge": {
      "backgroundColor": "#173A79"
    }
  },
  "cordova": {
    "preferences": {
      "BuildOpenBSDFilters": "false"
    }
  }
}
