{
  "name": "relaymarathon",
  "version": "1.5.0",
  "description": "Milano Relay Marathon  built with Quasar, Firebase, and Capacitor",
  "productName": "Milano Relay Marathon",
  "author": "giova",
  "private": true,
  "scripts": {
    "lint": "eslint --ext .js,.ts,.vue ./",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No tests specified\" && exit 0",
    "dev": "quasar dev",
    "dev:android": "quasar dev -m capacitor -T android",
    "build": "echo \"Building version:\" && node version.js get && quasar build",
    "build:pwa": "quasar build -m pwa",
    "build:android": "quasar build -m capacitor -T android",
    "dev:android:install": "cd src-capacitor && npx cap run android",
    "sync:android": "cd src-capacitor && npx cap sync android",
    "run:android": "cd src-capacitor && npx cap run android",
    "version": "node version.js",
    "deploy:web": "node scripts/deploy-ftp.js",
    "release:android": "powershell -ExecutionPolicy Bypass -File scripts/release-android.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.1",
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "@capacitor/ios": "^7.6.1",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@capgo/capacitor-social-login": "^7.20.0",
    "@quasar/extras": "^1.0.0",
    "firebase": "^10.14.1",
    "quasar": "^2.17.0",
    "vue": "^3.3.4",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@quasar/app-vite": "^2.5.4",
    "@quasar/icongenie": "^4.0.0",
    "@types/node": "^22.19.15",
    "autoprefixer": "^10.4.21",
    "basic-ftp": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "vue-eslint-parser": "^10.4.0",
    "workbox-build": "^7.4.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "engines": {
    "node": ">=14",
    "npm": ">=5.6.0",
    "yarn": ">=1.6.0"
  },
  "versionCode": 6
}
